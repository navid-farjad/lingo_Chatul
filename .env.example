# =====================================================================
# lingo_Chatul — environment template
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# --- Anthropic (Claude — mnemonic story generation) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Fal AI (image generation — Google nano-banana) ---
FAL_KEY=key_id:key_secret

# --- ElevenLabs (text-to-speech) ---
ELEVENLABS_API_KEY=sk_...

# --- Cloudflare R2 ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=lang
R2_PUBLIC_URL=https://pub-<id>.r2.dev

# --- Cloudflare DNS ---
CLOUDFLARE_DNS_TOKEN=
CLOUDFLARE_ZONE=lingochatul.com

# --- Hetzner deploy target ---
HETZNER_HOST=
HETZNER_USER=root
HETZNER_SSH_KEY=~/.ssh/lingo_chatul

# --- Database ---
DATABASE_URL=postgresql://lingo_chatul:lingo_chatul@localhost:5432/lingo_chatul_development

# --- Rails ---
RAILS_ENV=development
