{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lingo-chatul-web",
  "compatibility_date": "2026-01-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "app.lingochatul.com",
      "custom_domain": true
    }
  ]
}
