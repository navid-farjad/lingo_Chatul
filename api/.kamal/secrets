# Kamal secrets — sourced from the repo-root `.env` (which is gitignored).
# This file IS committed; never put raw secret values here.
# Pre-deploy hook seeds .env into the environment.

# Load all KEY=VALUE pairs from ../.env into this shell context.
SECRETS_FILE="../.env"
if [ -f "$SECRETS_FILE" ]; then
  set -a
  . "$SECRETS_FILE"
  set +a
fi

# Rails master key (read from local file, not stored in .env).
RAILS_MASTER_KEY=$(cat config/master.key)

# Container registry (GitHub Container Registry) — KAMAL_REGISTRY_PASSWORD
# must be a GitHub Personal Access Token (classic) with `write:packages` scope.
# Either export it in your shell, or add it to ../.env as KAMAL_REGISTRY_PASSWORD.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-}

# Postgres credentials (the accessory and the Rails app share these).
POSTGRES_PASSWORD=${API_DATABASE_PASSWORD:-}
API_DATABASE_PASSWORD=${API_DATABASE_PASSWORD:-}

# AI service keys
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
FAL_KEY=${FAL_KEY:-}
ELEVENLABS_API_KEY=${ELEVENLABS_API_KEY:-}

# Cloudflare R2 (S3-compatible) credentials
R2_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID:-}
R2_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY:-}
